# Copy this to .streamlit/secrets.toml and fill in your credentials
# Note: Do NOT commit secrets.toml - it's only for local development
# On Streamlit Cloud, set these via the Secrets dashboard

# --- Database connection (required for Streamlit Cloud deployment) ---
#
# Option A (recommended): discrete fields. The app builds the connection
# string for you and safely encodes special characters in the password
# (e.g. Supabase passwords often contain '@', which breaks a hand-built
# "postgresql://user:pass@host/db" string). Use Supabase's connection
# POOLER host here (Settings -> Database -> Connection pooling), not the
# direct db.<ref>.supabase.co host - Streamlit Cloud cannot reach it over
# IPv6-only direct connections.
db_host = "aws-0-xxxx.pooler.supabase.com"
db_port = 6543
db_user = "postgres.xxxxxxxxxxxx"
db_password = "your-raw-password-here"
db_name = "postgres"

# Option B: a single pre-built URL. If you use this instead, make sure any
# special characters in the password are percent-encoded (e.g. '@' -> '%40').
# database_url = "postgresql://user:password@host:5432/dbname"

# Slack webhook (optional)
slack_webhook_url = ""

# Anthropic API key (optional)
anthropic_api_key = ""

# Drift threshold
drift_threshold = 0.5
