# Copy this to .streamlit/secrets.toml and fill in your credentials
# Note: Do NOT commit secrets.toml - it's only for local development
# On Streamlit Cloud, set these via the Secrets dashboard

# Database URL (required for Streamlit Cloud deployment)
database_url = "postgresql://user:password@host:5432/dbname"

# Slack webhook (optional)
slack_webhook_url = ""

# Anthropic API key (optional)
anthropmic_api_key = ""

# Drift threshold
drift_threshold = 0.5
