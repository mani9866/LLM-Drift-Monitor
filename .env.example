# Database Configuration
# If DB_HOST is set, it takes priority: the app builds the connection URL
# from these discrete fields and safely encodes special characters in the
# password (e.g. Supabase passwords often contain '@'). Otherwise it falls
# back to DATABASE_URL below.
DB_HOST=localhost
DB_PORT=5432
DB_USER=drift_user
DB_PASSWORD=drift_password
DB_NAME=drift_monitor
DATABASE_URL=postgresql://drift_user:drift_password@localhost:5432/drift_monitor

# Slack Integration (optional)
SLACK_WEBHOOK_URL=

# Anthropic API (for data generation)
ANTHROPIC_API_KEY=

# Drift Detection Threshold (0.0 to 1.0)
DRIFT_THRESHOLD=0.5

# Environment
ENVIRONMENT=development
DEBUG=true
